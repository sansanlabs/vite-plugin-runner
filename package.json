{
  "name": "@sansanlabs/vite-plugin-runner",
  "version": "0.1.0",
  "description": "Run commands when Vite starts or a file changes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "keywords": ["vite", "plugin", "runner", "laravel", "php"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sansanlabs/vite-plugin-runner.git"
  },
  "homepage": "https://github.com/sansanlabs/vite-plugin-runner#readme",
  "bugs": {
    "url": "https://github.com/sansanlabs/vite-plugin-runner/issues"
  }
}